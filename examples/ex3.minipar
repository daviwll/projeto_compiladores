print(a)
while(a <= 15)
{
  print("oi")
  a = a + 1
  if(a == 12){break}
  print(a)
}

print(a)

if (a < 13)
{
  print("a é maior ou igual que 13")
}

func soma(num1: number, num2: number) -> number
{
  return num1 + num2
}

var res: number = soma(2, (3 + 4)*6)
print("res =", res)

